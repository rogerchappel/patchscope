{
  "name": "patchscope",
  "version": "0.1.0",
  "description": "Local-first git patch risk radar with deterministic Markdown and JSON output.",
  "type": "module",
  "bin": {
    "patchscope": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/args.d.ts",
    "dist/args.js",
    "dist/args.js.map",
    "dist/cli.d.ts",
    "dist/cli.js",
    "dist/cli.js.map",
    "dist/git.d.ts",
    "dist/git.js",
    "dist/git.js.map",
    "dist/help.d.ts",
    "dist/help.js",
    "dist/help.js.map",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/index.js.map",
    "dist/io.d.ts",
    "dist/io.js",
    "dist/io.js.map",
    "dist/package-scripts.d.ts",
    "dist/package-scripts.js",
    "dist/package-scripts.js.map",
    "dist/parser.d.ts",
    "dist/parser.js",
    "dist/parser.js.map",
    "dist/paths.d.ts",
    "dist/paths.js",
    "dist/paths.js.map",
    "dist/render-json.d.ts",
    "dist/render-json.js",
    "dist/render-json.js.map",
    "dist/render-markdown.d.ts",
    "dist/render-markdown.js",
    "dist/render-markdown.js.map",
    "dist/risks.d.ts",
    "dist/risks.js",
    "dist/risks.js.map",
    "dist/scan.d.ts",
    "dist/scan.js",
    "dist/scan.js.map",
    "dist/secrets.d.ts",
    "dist/secrets.js",
    "dist/secrets.js.map",
    "dist/summary.d.ts",
    "dist/summary.js",
    "dist/summary.js.map",
    "dist/types.d.ts",
    "dist/types.js",
    "dist/types.js.map",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "git",
    "diff",
    "review",
    "cli",
    "security",
    "testing"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/patchscope.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/patchscope/issues"
  },
  "homepage": "https://github.com/rogerchappel/patchscope#readme"
}
